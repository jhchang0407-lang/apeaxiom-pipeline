# ── Required ─────────────────────────────────────────────────────
# Financial Modeling Prep — market data, estimates, peers
FMP_API_KEY=your_fmp_key_here

# OpenAI — section writing, research agents, fact-check
OPENAI_API_KEY=your_openai_key_here

# SEC EDGAR requires a User-Agent identifying you with a contact email.
# https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT="Your Name your.email@example.com"

# ── Required for --upload / website mode (Cloudflare R2) ─────────
# Endpoint looks like https://<account-id>.r2.cloudflarestorage.com
CF_R2_ENDPOINT=
CF_R2_ACCESS_KEY=
CF_R2_SECRET_KEY=
CF_R2_BUCKET=

# ── Optional ─────────────────────────────────────────────────────
# Override the default models (default: gpt-5-mini for all stages)
# WRITER_MODEL=gpt-5-mini
# RESEARCH_AGENT_MODEL=gpt-5-mini
# PEER_SELECTION_MODEL=gpt-5-mini

# Discord webhook for scorecard notifications
# DISCORD_WEBHOOK_URL=

# Override the on-disk API cache location (default: ./cache)
# CACHE_DIR=
